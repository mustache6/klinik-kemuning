<!DOCTYPE html>
<html>
<head>
  <title>Data Obat</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background-color: #f4f6f9;
    }

    .card {
      border-radius: 15px;
    }

    .table thead {
      background-color: #198754;
      color: white;
    }

    .btn-custom {
      border-radius: 20px;
      padding: 5px 15px;
    }
  </style>
</head>

<body>

<div class="container mt-5">

  <div class="card shadow p-4">

    <h3 class="mb-4 text-center">Data Obat</h3>

    <a href="/obat/tambah" class="btn btn-success mb-3">+ Tambah Obat</a>

    <table class="table table-hover table-bordered text-center align-middle">
      <thead>
        <tr>
          <th>No</th>
          <th>Nama Obat</th>
          <th>Stok</th>
          <th>Harga</th>
          <th>Aksi</th>
        </tr>
      </thead>

      <tbody>
        <% obat.forEach((o, i) => { %>
        <tr>
          <td><%= i+1 %></td>
          <td><%= o.nama_obat %></td>
          <td><%= o.stok %></td>
          <td>Rp <%= o.harga %></td>
          <td>
            <a href="/obat/edit/<%= o.id %>" class="btn btn-warning btn-sm btn-custom">Edit</a>
            <a href="/obat/hapus/<%= o.id %>" class="btn btn-danger btn-sm btn-custom"
               onclick="return confirm('Yakin hapus data?')">Hapus</a>
          </td>
        </tr>
        <% }) %>
      </tbody>

    </table>

  </div>

</div>

</body>
</html>