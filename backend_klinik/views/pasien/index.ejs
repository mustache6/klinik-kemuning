<!DOCTYPE html>
<html>
<head>
  <title>Data Pasien</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background-color: #f4f6f9;
    }

    .card {
      border-radius: 15px;
    }

    .table thead {
      background-color: #0d6efd;
      color: white;
    }

    .btn-custom {
      border-radius: 20px;
      padding: 5px 15px;
    }
  </style>
</head>

<body>

<div class="container mt-5">

  <div class="card shadow p-4">

    <h3 class="mb-4 text-center">Data Pasien</h3>

    <a href="/pasien/tambah" class="btn btn-success mb-3">+ Tambah Pasien</a>

    <table class="table table-hover table-bordered text-center align-middle">
      <thead>
        <tr>
          <th>No</th>
          <th>Nama</th>
          <th>NIK</th>
          <th>Alamat</th>
          <th>No HP</th>
          <th>Tanggal Lahir</th>
          <th>Aksi</th>
        </tr>
      </thead>

      <tbody>
        <% pasien.forEach((p, i) => { %>
        <tr>
          <td><%= i + 1 %></td>
          <td><%= p.nama %></td>
          <td><%= p.nik %></td>
          <td><%= p.alamat %></td>
          <td><%= p.no_hp %></td>
          <td><%= p.tanggal_lahir %></td>
          <td>
            <a href="/pasien/edit/<%= p.id %>" class="btn btn-warning btn-sm btn-custom">Edit</a>
            <a href="/pasien/hapus/<%= p.id %>" class="btn btn-danger btn-sm btn-custom"
               onclick="return confirm('Yakin hapus data?')">Hapus</a>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>

  </div>

</div>

</body>
</html>