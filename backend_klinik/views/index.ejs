<!DOCTYPE html>
<html>
<head>

<title>Dashboard Klinik Kemuning</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
background:#f4f6f9;
}

.card{
border:none;
border-radius:10px;
box-shadow:0 4px 10px rgba(0,0,0,0.1);
}

</style>

</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-primary">

<div class="container-fluid">

<a class="navbar-brand">
Klinik Kemuning
</a>

<div>

<span class="text-white me-3">
Halo, <b><%= user.username %></b>
</span>

<a href="/logout" class="btn btn-light btn-sm">
Logout
</a>

</div>

</div>

</nav>


<div class="container mt-5">

<h2 class="text-center text-primary mb-5">
Selamat Datang di Klinik Kemuning
</h2>

<div class="row g-4">

<div class="col-md-4">

<div class="card bg-info text-white text-center">

<div class="card-body">

<h4>Data Pasien</h4>

<p>Lihat semua pasien terdaftar</p>

<a href="/pasien" class="btn btn-light">
Lihat
</a>

</div>

</div>

</div>


<div class="col-md-4">

<div class="card bg-success text-white text-center">

<div class="card-body">

<h4>Data Obat</h4>

<p>Informasi obat tersedia</p>

<a href="/obat" class="btn btn-light">
Lihat
</a>

</div>

</div>

</div>


<div class="col-md-4">

<div class="card bg-warning text-dark text-center">

<div class="card-body">

<h4>Rekam Medis</h4>

<p>Cek rekam medis pasien</p>

<a href="/rekam_medis" class="btn btn-dark">
Lihat
</a>

</div>

</div>

</div>

</div>

</div>

</body>
</html>