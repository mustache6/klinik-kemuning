<!DOCTYPE html>
<html>
<head>
  <title>Dashboard Klinik</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background-color: #f5f6fa;
    }

    .sidebar {
      height: 100vh;
      background-color: #2f3640;
      color: white;
      padding: 20px;
    }

    .sidebar a {
      color: white;
      display: block;
      margin: 10px 0;
      text-decoration: none;
    }

    .sidebar a:hover {
      background-color: #353b48;
      padding-left: 10px;
    }

    .card-menu {
      border-radius: 12px;
      padding: 20px;
      color: white;
    }
  </style>
</head>

<body>

<div class="container-fluid">
  <div class="row">

    <!-- SIDEBAR -->
    <div class="col-md-2 sidebar">
      <h4>Klinik</h4>
      <hr>

      <a href="/">Dashboard</a>
      <a href="/pasien">Data Pasien</a>
      <a href="/obat">Data Obat</a>
      <a href="/rekammedis">Rekam Medis</a>
      <a href="/auth/logout">Logout</a>
    </div>

    <!-- CONTENT -->
    <div class="col-md-10 p-4">

      <h2>Dashboard Klinik Kemuning</h2>
      <p>Selamat datang <b><%= user.username %></b></p>

      <div class="row mt-4">

        <!-- PASIEN -->
        <div class="col-md-4">
          <div class="card-menu bg-primary">
            <h4>Data Pasien</h4>
            <p>Kelola data pasien</p>
            <a href="/pasien" class="btn btn-light">Lihat</a>
          </div>
        </div>

        <!-- OBAT -->
        <div class="col-md-4">
          <div class="card-menu bg-success">
            <h4>Data Obat</h4>
            <p>Kelola data obat</p>
            <a href="/obat" class="btn btn-light">Lihat</a>
          </div>
        </div>

        <!-- REKAM MEDIS -->
        <div class="col-md-4">
          <div class="card-menu bg-warning">
            <h4>Rekam Medis</h4>
            <p>Kelola rekam medis</p>
            <a href="/rekammedis" class="btn btn-dark">Lihat</a>
          </div>
        </div>

      </div>

    </div>

  </div>
</div>

</body>
</html>