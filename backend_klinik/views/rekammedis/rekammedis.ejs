<h2 class="text-warning mb-3">Data Rekam Medis</h2>
<table class="table table-striped table-bordered">
  <thead class="table-dark">
    <tr>
      <th>ID</th>
      <th>Pasien ID</th>
      <th>Diagnosis</th>
      <th>Pengobatan</th>
      <th>Tanggal</th>
    </tr>
  </thead>
  <tbody>
    <% rekam.forEach(r => { %>
      <tr>
        <td><%= r.id %></td>
        <td><%= r.pasien_id %></td>
        <td><%= r.diagnosis %></td>
        <td><%= r.pengobatan %></td>
        <td><%= r.tanggal %></td>
      </tr>
    <% }) %>
  </tbody>
</table>
